# Minimal defaults; user can set target/USB options via `idf.py menuconfig`.

# Enable TinyUSB device stack.
CONFIG_TINYUSB_CDC_ENABLED=y
CONFIG_TINYUSB_HID_COUNT=1

# NimBLE (preferred BLE host).
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_HOST_ENABLED=y
CONFIG_BT_NIMBLE_ROLE_CENTRAL=y
CONFIG_BT_NIMBLE_ROLE_OBSERVER=y

# Don't bind the console to USB-Serial/JTAG or USB-CDC here; we redirect logs to the
# TinyUSB CDC interface from code (see usb_hid_gamepad.c) to avoid peripheral conflicts.
CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
